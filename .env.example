# ── LLM Provider ─────────────────────────────────────────────────────────────
# "local"   → free OpenRouter fallback chain (no AWS needed)
# "bedrock" → AWS Bedrock (requires AWS credentials below)
LLM_PROVIDER=local

# ── Voice Output ──────────────────────────────────────────────────────────────
# Set to true to enable Amazon Polly TTS (requires AWS credentials)
POLLY_ENABLED=false

# ── AWS Credentials (required only for bedrock or Polly) ─────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ── Bedrock Model ─────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
